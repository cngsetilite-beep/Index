<!-- ═══════════════════════════════════════════
     PRIVACY & SECURITY SHIELD
     Blocks: right-click, F12, Ctrl+Shift+I/J/C,
     Ctrl+U, Ctrl+S, view-source, console, devtools
═══════════════════════════════════════════ -->
<script>
(function(){
"use strict";

/* Block right-click */
document.addEventListener('contextmenu',function(e){e.preventDefault();return false;},true);

/* Block keyboard shortcuts */
document.addEventListener('keydown',function(e){
  var k=e.key,c=e.keyCode;
  /* F12 */
  if(k==='F12'||c===123){e.preventDefault();e.stopPropagation();return false;}
  /* Ctrl or Cmd combos */
  if(e.ctrlKey||e.metaKey){
    /* Ctrl+U view-source, Ctrl+S save, Ctrl+P print, Ctrl+A select-all */
    if(k==='u'||k==='U'||k==='s'||k==='S'||k==='p'||k==='P'||k==='a'||k==='A'){
      e.preventDefault();e.stopPropagation();return false;
    }
    /* Ctrl+Shift+I/J/C/K devtools */
    if(e.shiftKey&&(k==='i'||k==='I'||k==='j'||k==='J'||k==='c'||k==='C'||k==='k'||k==='K')){
      e.preventDefault();e.stopPropagation();return false;
    }
    /* By keyCode */
    if(c===73||c===74||c===67||c===85||c===83||c===80||c===65){
      e.preventDefault();e.stopPropagation();return false;
    }
  }
  /* Alt+F4 / browser shortcuts */
  if(e.altKey&&(k==='F4'||c===115)){e.preventDefault();return false;}
},true);

document.addEventListener('keyup',function(e){
  if(e.keyCode===123){e.preventDefault();return false;}
},true);

/* Disable text selection drag */
document.addEventListener('selectstart',function(e){e.preventDefault();return false;});
document.addEventListener('dragstart',function(e){e.preventDefault();return false;});

/* Block mouse right-button */
document.addEventListener('mousedown',function(e){
  if(e.button===2){e.preventDefault();return false;}
},true);

/* Disable copy / cut */
document.addEventListener('copy',function(e){e.preventDefault();return false;});
document.addEventListener('cut', function(e){e.preventDefault();return false;});

/* ── Override all console methods ── */
(function(){
  var noop=function(){};
  var methods=['log','warn','error','info','debug','dir','table','trace',
               'group','groupCollapsed','groupEnd','time','timeEnd',
               'profile','profileEnd','assert','count','clear'];
  if(window.console){
    methods.forEach(function(m){
      try{window.console[m]=noop;}catch(x){}
    });
  }
  try{
    Object.defineProperty(window,'console',{
      get:function(){
        return{log:noop,warn:noop,error:noop,info:noop,debug:noop,
               dir:noop,table:noop,trace:noop,assert:noop,count:noop,clear:noop};
      },
      set:function(){}
    });
  }catch(x){}
})();

/* ── DevTools window-size detection ── */
(function(){
  var blocked=false;
  var OVERLAY='<div style="position:fixed;top:0;left:0;width:100%;height:100%;background:#fff;z-index:99999;display:flex;align-items:center;justify-content:center;font-family:-apple-system,sans-serif;font-size:17px;color:#1d1d1f;text-align:center;padding:24px">Developer tools are not permitted on this page.<br>Please close them to continue.</div>';
  function check(){
    var wDiff=window.outerWidth -window.innerWidth;
    var hDiff=window.outerHeight-window.innerHeight;
    if((wDiff>150||hDiff>150)&&!blocked){
      blocked=true;
      document.body.insertAdjacentHTML('afterbegin',OVERLAY);
    }
    if(wDiff<=150&&hDiff<=150&&blocked){
      blocked=false;
      var o=document.getElementById('devblock');
      if(o)o.remove();
      /* Reload to clear any tampering */
      location.reload();
    }
  }
  setInterval(check,800);
  window.addEventListener('resize',check);
})();

/* ── Anti-debugger trap ── */
(function(){
  function trap(){
    var t=+new Date();
    /* jshint ignore:start */
    debugger;
    /* jshint ignore:end */
    if(+new Date()-t>80){
      document.body.innerHTML='<div style="position:fixed;top:0;left:0;width:100%;height:100%;background:#fff;z-index:99999;display:flex;align-items:center;justify-content:center;font-family:-apple-system,sans-serif;font-size:17px;color:#1d1d1f;text-align:center;padding:24px">Developer tools are not permitted on this page.</div>';
    }
  }
  setInterval(trap,3500);
})();

/* ── Disable print ── */
window.addEventListener('beforeprint',function(e){e.stopImmediatePropagation();},true);
window.onbeforeprint=function(){return false;};

/* ── Questions toggle ── */
var qBtn=document.getElementById('qBtn');
if(qBtn){
  qBtn.addEventListener('click',function(){
    var o=this.classList.toggle('open');
    this.setAttribute('aria-expanded',o);
  });
}

})();

/* Mobile footer accordion */
function tfm(btn){
  btn.classList.toggle('open');
  btn.nextElementSibling.classList.toggle('open');
}
</script>

