.ft{background:var(--footer-bg);border-top:1px solid var(--border);margin-top:6px}
.ft-in{max-width:var(--max);margin:0 auto;padding:0 22px}
@media(max-width:734px){.ft-in{padding:0 16px}}
.ft-mini{font-size:12px;color:var(--sub);padding:14px 0;border-bottom:1px solid var(--border);line-height:1.6}
.ft-mini a{color:var(--blue)}
/* Desktop cols */
.ft-cols{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;padding:22px 0}
@media(max-width:900px){.ft-cols{grid-template-columns:repeat(3,1fr)}}
@media(max-width:734px){.ft-cols{display:none}}
.fc-title{font-size:12px;font-weight:600;color:var(--text);margin:16px 0 8px}
.fc-title:first-child{margin-top:0}
.fc ul{list-style:none}
.fc ul li{margin-bottom:6px}
.fc ul li a{font-size:12px;color:var(--sub)}
.fc ul li a:hover{text-decoration:underline}
/* Mobile accordion */
.ft-mob{display:none}
@media(max-width:734px){.ft-mob{display:block}}
.fm-sec{border-bottom:1px solid var(--border)}
.fm-btn{display:flex;justify-content:space-between;align-items:center;width:100%;padding:13px 0}
.fm-btn span{font-size:14px;color:var(--text)}
.fm-chev{width:12px;height:8px;color:var(--sub);transition:transform .2s;flex-shrink:0}
.fm-btn.open .fm-chev{transform:rotate(180deg)}
.fm-body{display:none;padding-bottom:10px}
.fm-body.open{display:block}
.fm-body ul{list-style:none}
.fm-body ul li{margin-bottom:9px}
.fm-body ul li a{font-size:14px;color:var(--sub)}
/* Footer bottom bar */
.ft-bot{border-top:1px solid var(--border);padding:14px 0}
.fb{max-width:var(--max);margin:0 auto;padding:0 22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;font-size:12px;color:var(--sub)}
@media(max-width:734px){.fb{padding:0 16px;flex-direction:column;align-items:flex-start;gap:5px}}
.fb-links{display:flex;gap:12px;flex-wrap:wrap}
.fb-links a{color:var(--sub)}.fb-links a:hover{text-decoration:underline}

