// ════════════════════════════════════════
//  ENCRYPTION CLASS
// ════════════════════════════════════════
class SecureAdvCrypt {
    private const METHOD = 'aes-256-ctr';
    private const FIXED_PASSWORD = 'ps6HjK9+vR2L5mN7qWz1Yx8TcA4PbG3fE6iU0oV9ZkM=';

    public static function encrypt(string $data): string {
        $masterKey  = hash('sha512', self::FIXED_PASSWORD, true);
        $encKey     = substr($masterKey, 0, 32);
        $authKey    = substr($masterKey, 32);
        $iv         = random_bytes(openssl_cipher_iv_length(self::METHOD));
        $ciphertext = openssl_encrypt($data, self::METHOD, $encKey, OPENSSL_RAW_DATA, $iv);
        $hmac       = hash_hmac('sha256', $iv . $ciphertext, $authKey, true);
        return base64_encode($iv . $hmac . $ciphertext);
    }

    public static function decrypt(string $encodedData): ?string {
        $masterKey  = hash('sha512', self::FIXED_PASSWORD, true);
        $encKey     = substr($masterKey, 0, 32);
        $authKey    = substr($masterKey, 32);
        $decoded    = base64_decode($encodedData, true);
        if (!$decoded) return null;
        $ivLen      = openssl_cipher_iv_length(self::METHOD);
        $iv         = substr($decoded, 0, $ivLen);
        $hmac       = substr($decoded, $ivLen, 32);
        $ciphertext = substr($decoded, $ivLen + 32);
        $calcHmac   = hash_hmac('sha256', $iv . $ciphertext, $authKey, true);
        if (!hash_equals($hmac, $calcHmac)) return null;
        return openssl_decrypt($ciphertext, self::METHOD, $encKey, OPENSSL_RAW_DATA, $iv);
    }
}

