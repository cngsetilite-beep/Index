$items  = [];
$isDemo = false;

if (!empty($_GET['data'])) {
    $decrypted = SecureAdvCrypt::decrypt(urldecode($_GET['data']));
    if ($decrypted !== null) {
        $parsed = json_decode($decrypted, true);
        if (is_array($parsed) && !empty($parsed['items'])) {
            $items = $parsed['items'];
        }
    }
}
if (empty($items)) { $items = $defaultItems; $isDemo = true; }

// Calculate totals
$cartTotal = 0; $itemCount = 0;
foreach ($items as $it) {
    $cartTotal += floatval($it['price']) * intval($it['qty']);
    $itemCount += intval($it['qty']);
}

