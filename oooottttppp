        $path = strtok($_SERVER['REQUEST_URI'], '?');
        $redirectUrl = $protocol . '://' . $host . $path;
        
        while (ob_get_level()) {
            ob_end_clean();
        }
        session_write_close();
        header("Location: $redirectUrl");
        exit;
    }
    
    // Token valid - restore parameters from session
    if (isset($_SESSION['stored_params'])) {
        $stored_params = $_SESSION['stored_params'];
        
        // Merge stored params with URL params - exclude timestamp as we handle expiry via session
        foreach ($stored_params as $key => $value) {
