<script>
// ============================================
// 1. RIGHT-CLICK DISABLE
// ============================================
document.addEventListener('contextmenu', function(e) {
  e.preventDefault();
  e.stopPropagation();
  return false;
}, true);

// ============================================
// 2. KEYBOARD SHORTCUTS BLOCK
// ============================================
document.addEventListener('keydown', function(e) {
  var key = e.key ? e.key.toLowerCase() : '';
  var code = e.code ? e.code.toLowerCase() : '';

  // F1–F12 keys
  if (e.keyCode >= 112 && e.keyCode <= 123) {
    e.preventDefault(); e.stopPropagation(); return false;
  }

  // Ctrl / Cmd combinations
  if (e.ctrlKey || e.metaKey) {
    var blocked = [
      'u',  // View Source
      's',  // Save
      'a',  // Select All
      'c',  // Copy
      'v',  // Paste
      'x',  // Cut
      'p',  // Print
      'f',  // Find
      'g',  // Find Next
      'h',  // History / Find-Replace
      'j',  // Downloads / Console (Firefox)
      'k',  // Console (some browsers)
      'i',  // Inspector
      'l',  // Address bar
      'n',  // New window
      't',  // New tab
      'w',  // Close tab
      'r',  // Reload
      'b',  // Bookmarks
    ];
    if (blocked.indexOf(key) !== -1) {
      e.preventDefault(); e.stopPropagation(); return false;
    }

    // Ctrl+Shift combinations
    if (e.shiftKey) {
      var blockedShift = ['i','j','c','k','e','m','p','q','r','s','u'];
      if (blockedShift.indexOf(key) !== -1) {
        e.preventDefault(); e.stopPropagation(); return false;
      }
    }
  }

  // Alt+F4 / Alt combinations
  if (e.altKey && key === 'f4') {
    e.preventDefault(); return false;
  }
}, true);

document.addEventListener('keyup', function(e) {
  if (e.keyCode >= 112 && e.keyCode <= 123) {
    e.preventDefault(); return false;
  }
}, true);

document.addEventListener('keypress', function(e) {
  if (e.ctrlKey || e.metaKey) {
    e.preventDefault(); return false;
  }
}, true);

// ============================================
// 3. TEXT SELECTION DISABLE
// ============================================
document.addEventListener('selectstart', function(e) {
  e.preventDefault(); return false;
}, true);

document.addEventListener('dragstart', function(e) {
  e.preventDefault(); return false;
}, true);

// ============================================
// 4. COPY / CUT / PASTE DISABLE
// ============================================
['copy','cut','paste'].forEach(function(evt) {
  document.addEventListener(evt, function(e) {
    e.preventDefault(); return false;
  }, true);
});

// ============================================
// 5. PRINT DISABLE (Ctrl+P & window.print)
// ============================================
window.addEventListener('beforeprint', function(e) {
  e.preventDefault();
  document.body.innerHTML = '<h1 style="text-align:center;margin-top:40vh;color:red;">Printing Not Allowed!</h1>';
});

window.onbeforeprint = function() { return false; };

(function() {
  var origPrint = window.print;
  window.print = function() {
    console.clear();
    return false;
  };
})();

// ============================================
// 6. DEVTOOLS DETECTION (Multiple Methods)
// ============================================
var devtoolsOpen = false;
var warning = document.getElementById('devtools-warning');

// Method A: Window size difference detection
function checkDevToolsBySize() {
  var threshold = 160;
  var widthDiff  = window.outerWidth  - window.innerWidth;
  var heightDiff = window.outerHeight - window.innerHeight;
  if (widthDiff > threshold || heightDiff > threshold) {
    openWarning();
  } else {
    closeWarning();
  }
}

// Method B: console.log timing trick
function checkDevToolsByConsole() {
  var start = performance.now();
  // Accessing .id triggers getter when DevTools is open
  var el = new Image();
  Object.defineProperty(el, 'id', {
    get: function() {
      devtoolsOpen = true;
      openWarning();
    }
  });
  console.log('%c', el);
  console.clear();
}

// Method C: debugger timing
function checkDebugger() {
  var start = new Date();
  debugger;
  var diff = new Date() - start;
  if (diff > 100) {
    openWarning();
  }
}

function openWarning() {
  if (!devtoolsOpen) {
    devtoolsOpen = true;
    warning.classList.add('active');
    // Optionally redirect
    // window.location.href = 'https://yoursite.com/blocked';
  }
}

function closeWarning() {
  if (devtoolsOpen) {
    devtoolsOpen = false;
    warning.classList.remove('active');
  }
}

// Run checks repeatedly
setInterval(checkDevToolsBySize, 500);
setInterval(checkDevToolsByConsole, 1000);
setInterval(checkDebugger, 2000);

// ============================================
// 7. CONSOLE CLEAR & OVERRIDE
// ============================================
setInterval(function() { console.clear(); }, 500);

// Override all console methods
(function() {
  var noop = function() {};
  var methods = ['log','warn','error','info','debug','table','dir',
                 'dirxml','group','groupEnd','time','timeEnd',
                 'count','trace','profile','profileEnd'];
  methods.forEach(function(m) {
    try { console[m] = noop; } catch(e) {}
  });
})();

// Warn message in console (discourages hackers)
Object.defineProperty(console, '_commandLineAPI', {
  get: function() { throw new Error('Inspect Karna Mana Hai!'); }
});

// ============================================
// 8. IFRAME EMBEDDING BLOCK (Clickjacking)
// ============================================
if (window.top !== window.self) {
  window.top.location = window.self.location;
}

// ============================================
// 9. DISABLE VIEW-SOURCE VIA KEYBOARD
// ============================================
// Already handled above via Ctrl+U block.
// Extra safety: override document.write
document.write = function() { return false; };

// ============================================
// 10. TOUCH LONG-PRESS (Mobile Right Click)
// ============================================
document.addEventListener('touchstart', function(e) {
  if (e.touches.length > 1) { e.preventDefault(); }
}, { passive: false });

var touchTimer;
document.addEventListener('touchstart', function() {
  touchTimer = setTimeout(function() {}, 600);
}, false);
document.addEventListener('touchend', function() {
  clearTimeout(touchTimer);
}, false);

document.addEventListener('touchmove', function(e) {
  clearTimeout(touchTimer);
}, false);

</script>

