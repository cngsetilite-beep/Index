<title>Bag - Apple</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:-apple-system,BlinkMacSystemFont,'SF Pro Text','Helvetica Neue',Arial,sans-serif;background:#fff;color:#1d1d1f;font-size:17px;}
  a{color:#0071e3;text-decoration:none;}
  a:hover{text-decoration:underline;}

  /* ===== NAV ===== */
  nav.global-nav{background:rgba(255,255,255,0.85);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid rgba(0,0,0,0.1);position:sticky;top:0;z-index:100;height:44px;}
  .nav-inner{max-width:1024px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:44px;padding:0 22px;}
  .nav-logo svg{width:18px;height:22px;fill:#1d1d1f;display:block;}
  .nav-links{display:flex;gap:0;list-style:none;}
  .nav-links li a{font-size:12px;color:#1d1d1f;padding:0 10px;line-height:44px;display:block;white-space:nowrap;opacity:.88;}
  .nav-links li a:hover{opacity:1;text-decoration:none;}
  .nav-actions{display:flex;align-items:center;gap:16px;}
  .nav-actions svg{width:18px;height:18px;fill:#1d1d1f;cursor:pointer;}
  @media(max-width:768px){
    .nav-links{display:none;}
    .nav-inner{justify-content:space-between;}
  }

  /* ===== MAIN CONTAINER ===== */
  .bag-page{max-width:1024px;margin:0 auto;padding:0 22px 60px;}

  /* ===== HEADER ===== */
  .bag-header{text-align:center;padding:48px 0 32px;}
  .bag-header h1{font-size:32px;font-weight:600;letter-spacing:-.5px;color:#1d1d1f;}
  .bag-header p{font-size:17px;color:#1d1d1f;margin-top:6px;}
  @media(max-width:768px){
    .bag-header h1{font-size:24px;}
    .bag-header p{font-size:14px;}
  }

  /* ===== CHECKOUT BUTTONS ===== */
  .checkout-row{display:flex;gap:12px;justify-content:center;padding-bottom:32px;}
  .btn-apple-pay{background:#000;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:17px;cursor:pointer;display:flex;align-items:center;gap:8px;font-family:inherit;min-width:220px;justify-content:center;flex:1;max-width:300px;}
  .btn-apple-pay svg{width:36px;height:20px;fill:#fff;}
  .btn-checkout{background:#0071e3;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:17px;cursor:pointer;font-family:inherit;min-width:220px;justify-content:center;flex:1;max-width:300px;}
  .btn-checkout:hover{background:#0077ed;}
  @media(max-width:480px){
    .checkout-row{flex-direction:column;align-items:stretch;}
    .btn-apple-pay,.btn-checkout{max-width:100%;}
  }

  /* ===== DIVIDER ===== */
  hr.divider{border:none;border-top:1px solid #d2d2d7;margin:0;}

  /* ===== CART ITEM ===== */
  .cart-item{display:grid;grid-template-columns:200px 1fr auto auto;align-items:start;padding:32px 0;gap:20px;border-bottom:1px solid #d2d2d7;}
  .cart-item-img{width:160px;height:160px;object-fit:contain;display:block;}
  .cart-item-info{padding-top:4px;}
  .cart-item-info h2{font-size:19px;font-weight:400;color:#1d1d1f;margin-bottom:0;}
  .qty-wrapper{display:flex;align-items:center;gap:4px;margin-top:2px;}
  .qty-select{font-size:15px;color:#1d1d1f;border:none;background:transparent;cursor:pointer;-webkit-appearance:none;appearance:none;padding-right:14px;position:relative;}
  .qty-select-wrap{position:relative;display:inline-block;}
  .qty-select-wrap::after{content:'▾';position:absolute;right:0;top:50%;transform:translateY(-50%);font-size:11px;pointer-events:none;color:#1d1d1f;}
  .cart-item-price{font-size:19px;color:#1d1d1f;text-align:right;padding-top:4px;min-width:80px;}
  .cart-item-actions{text-align:right;display:flex;flex-direction:column;gap:4px;padding-top:28px;}
  .cart-item-actions a{font-size:14px;color:#0071e3;display:block;}

  /* Gift card details */
  .gift-details{margin-top:20px;padding:14px 16px;border:1px solid #d2d2d7;border-radius:6px;font-size:14px;color:#1d1d1f;background:#fff;}
  .gift-details-header{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:500;margin-bottom:10px;}
  .gift-details-header svg{width:20px;height:20px;}
  .gift-details-header .edit-link{margin-left:auto;color:#0071e3;font-weight:400;cursor:pointer;}
  .gift-row{margin-bottom:4px;}
  .gift-row strong{display:block;font-weight:500;}
  .gift-row span{color:#1d1d1f;}
  .arrives{margin-top:16px;font-size:14px;color:#1d1d1f;}

  /* Responsive cart item */
  @media(max-width:768px){
    .cart-item{grid-template-columns:120px 1fr;grid-template-rows:auto auto;}
    .cart-item-img{width:100px;height:100px;}
    .cart-item-price{grid-column:2;grid-row:1;text-align:right;padding-top:4px;}
    .cart-item-actions{grid-column:2;grid-row:2;padding-top:0;}
    .cart-item-info{grid-column:2;grid-row:1;}
  }
  @media(max-width:480px){
    .cart-item{grid-template-columns:90px 1fr;}
    .cart-item-img{width:80px;height:80px;}
    .bag-header h1{font-size:22px;}
  }

  /* ===== SUMMARY ===== */
  .summary-section{padding:24px 0;border-bottom:1px solid #d2d2d7;}
  .summary-row{display:flex;justify-content:space-between;font-size:17px;padding:4px 0;}
  .summary-row.total{font-weight:600;font-size:19px;padding-top:10px;}
  .daily-cash-link{font-size:12px;color:#0071e3;display:block;text-align:right;margin-top:2px;}

  /* ===== BOTTOM CHECKOUT ===== */
  .bottom-checkout{padding:24px 0;border-bottom:1px solid #d2d2d7;}
  .checkout-bottom-row{display:flex;gap:12px;justify-content:flex-end;}
  @media(max-width:600px){
    .checkout-bottom-row{flex-direction:column;}
  }
  .btn-apple-pay-sm{background:#000;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:17px;cursor:pointer;display:flex;align-items:center;gap:8px;font-family:inherit;min-width:200px;justify-content:center;}
  .btn-apple-pay-sm svg{width:36px;height:20px;fill:#fff;}
  .btn-checkout-sm{background:#0071e3;color:#fff;border:none;border-radius:8px;padding:14px 28px;font-size:17px;cursor:pointer;font-family:inherit;min-width:200px;text-align:center;}
  .btn-checkout-sm:hover{background:#0077ed;}
  @media(max-width:600px){
    .btn-apple-pay-sm,.btn-checkout-sm{min-width:unset;width:100%;}
  }

  /* ===== YOU MAY ALSO LIKE ===== */
  .also-like{padding:48px 0 32px;}
  .also-like h2{font-size:24px;font-weight:600;text-align:center;margin-bottom:32px;}
  .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  .product-card{text-align:center;}
  .product-card img{width:100%;max-width:220px;height:180px;object-fit:contain;display:block;margin:0 auto 12px;}
  .product-tag{font-size:12px;color:#bf4800;margin-bottom:4px;}
  .product-name{font-size:14px;color:#1d1d1f;margin-bottom:4px;line-height:1.4;}
  .product-price{font-size:14px;color:#1d1d1f;margin-bottom:12px;}
  .color-swatches{display:flex;justify-content:center;gap:6px;margin-bottom:12px;}
  .swatch{width:20px;height:20px;border-radius:50%;border:2px solid transparent;cursor:pointer;}
  .swatch.selected{border-color:#0071e3;}
  .color-label{font-size:12px;color:#6e6e73;margin-bottom:8px;}
  .btn-add-bag{background:#0071e3;color:#fff;border:none;border-radius:980px;padding:10px 20px;font-size:14px;cursor:pointer;font-family:inherit;width:100%;max-width:220px;}
  .btn-add-bag:hover{background:#0077ed;}
  @media(max-width:600px){
    .products-grid{grid-template-columns:1fr;gap:32px;}
  }

  /* ===== QUESTIONS ===== */
  .questions-section{border-top:1px solid #d2d2d7;padding:0;}
  .questions-toggle{display:flex;justify-content:space-between;align-items:center;padding:20px 0;cursor:pointer;}
  .questions-toggle h2{font-size:17px;font-weight:400;}
  .chevron{font-size:20px;color:#1d1d1f;transition:transform .3s;}
  .chevron.open{transform:rotate(180deg);}
  .questions-body{display:none;padding-bottom:20px;font-size:14px;color:#6e6e73;}
  .questions-body.open{display:block;}

  /* ===== BREADCRUMB ===== */
  .breadcrumb{font-size:12px;color:#6e6e73;padding:16px 0 0;display:flex;gap:6px;align-items:center;}
  .breadcrumb svg{width:6px;height:10px;fill:#6e6e73;}

  /* ===== FOOTER ===== */
  footer.site-footer{background:#f5f5f7;padding:20px 0 0;margin-top:20px;}
  .footer-inner{max-width:1024px;margin:0 auto;padding:0 22px;}
  .footer-top{font-size:12px;color:#6e6e73;padding:12px 0;border-bottom:1px solid #d2d2d7;}
  .footer-cols{display:grid;grid-template-columns:repeat(5,1fr);gap:20px;padding:20px 0;border-bottom:1px solid #d2d2d7;}
  .footer-col h4{font-size:12px;font-weight:600;color:#1d1d1f;margin-bottom:10px;}
  .footer-col ul{list-style:none;}
  .footer-col ul li{margin-bottom:6px;}
  .footer-col ul li a{font-size:12px;color:#6e6e73;}
  .footer-col ul li a:hover{color:#1d1d1f;text-decoration:none;}
  .footer-bottom{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;padding:12px 0;font-size:12px;color:#6e6e73;gap:8px;}
  .footer-bottom-links{display:flex;flex-wrap:wrap;gap:8px;}
  .footer-bottom-links a{color:#6e6e73;font-size:12px;}
  @media(max-width:768px){
    .footer-cols{grid-template-columns:repeat(2,1fr);}
  }
  @media(max-width:480px){
    .footer-cols{grid-template-columns:1fr;}
  }

  /* ===== APPLE PAY LOGO ===== */
  .apple-pay-logo{font-size:14px;letter-spacing:-.5px;font-weight:500;}
</style>
