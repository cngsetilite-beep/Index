<script>
// =============================================
// URL PARAMETER PARSING & PAGE POPULATION
// =============================================
// Supported URL parameters:
//   item1: to1_name, to1_email, from1_name, from1_email, msg1, qty1, price1
//   item2: to2_name, to2_email, from2_name, from2_email, msg2, qty2, price2
//   (up to 5 items: replace 1/2 with 3/4/5)
//
// Example URL:
// apple-bag.html?to1_name=hamad&to1_email=hamad12@hotmail.com&from1_name=hamada&from1_email=hamad12@hotmail.com&msg1=best+gift+vocher&qty1=1&price1=50&to2_name=hamad&to2_email=hamads@hotmail.com&from2_name=hadamd&from2_email=haamad@hotmail.com&msg2=best+gift+hamada&qty2=1&price2=50
// =============================================

const params = new URLSearchParams(window.location.search);

function p(key, def = '') {
  return params.get(key) || def;
}

function formatPrice(val) {
  const n = parseFloat(val);
  if (isNaN(n)) return '$0.00';
  return '$' + n.toFixed(2);
}

// Apple gift card SVG image (colorful apple logo)
const giftCardImg = `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 160'%3E%3Crect width='160' height='160' fill='%23f5f5f7'/%3E%3Cg transform='translate(30,10)'%3E%3Cpolygon points='50,10 70,30 50,50 30,30' fill='%23ff3b30'/%3E%3Cpolygon points='70,30 90,10 90,50 70,50' fill='%23ff9500'/%3E%3Cpolygon points='30,30 50,50 30,70 10,50' fill='%2334c759'/%3E%3Cpolygon points='50,50 70,50 70,90 50,70' fill='%230071e3'/%3E%3Cpolygon points='30,70 50,70 50,110 30,90' fill='%235856d6'/%3E%3Cpolygon points='70,50 90,50 90,90 70,70' fill='%23ffcc00'/%3E%3Cpolygon points='50,70 70,70 70,110 50,90' fill='%2300c7be'/%3E%3Cpolygon points='10,50 30,70 10,90 -10,70' fill='%23ff2d55'/%3E%3Cpolygon points='90,10 100,30 80,30' fill='%23bf5af2'/%3E%3C/g%3E%3C/svg%3E`;

// Larger, better Apple multicolor logo as base64-ish inline
const appleLogoSVG = `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="160" height="160">
  <rect width="200" height="200" fill="#f5f5f7"/>
  <g transform="translate(100,100)">
    <polygon points="0,-60 35,-20 0,20 -35,-20" fill="#FF6B6B"/>
    <polygon points="35,-20 70,-60 70,20 35,20" fill="#FFA500"/>
    <polygon points="-35,-20 0,20 -35,60 -70,20" fill="#4CAF50"/>
    <polygon points="0,20 35,20 35,60 0,60" fill="#2196F3"/>
    <polygon points="-35,20 0,20 0,60 -35,60" fill="#9C27B0"/>
    <polygon points="35,20 70,20 70,60 35,60" fill="#FFEB3B"/>
    <polygon points="0,60 35,60 0,80" fill="#00BCD4"/>
    <polygon points="0,-80 35,-60 0,-60 -35,-60" fill="#E91E63"/>
  </g>
</svg>`;

// Build cart items from URL params
const container = document.getElementById('cart-items-container');
let grandTotal = 0;
let hasItems = false;

for (let i = 1; i <= 5; i++) {
  const toName    = p(`to${i}_name`);
  const toEmail   = p(`to${i}_email`);
  const fromName  = p(`from${i}_name`);
  const fromEmail = p(`from${i}_email`);
  const msg       = p(`msg${i}`);
  const qty       = p(`qty${i}`, '1');
  const price     = p(`price${i}`, '0');

  // Stop if no recipient name and this isn't item1 with defaults
  if (!toName && !toEmail && !fromName && !fromEmail && !msg && i > 1) continue;
  if (!toName && !toEmail && !fromName && !fromEmail && !msg && price === '0') continue;

  hasItems = true;
  const priceNum = parseFloat(price) || 0;
  const qtyNum   = parseInt(qty) || 1;
  const itemTotal = priceNum * qtyNum;
  grandTotal += itemTotal;

  // Build quantity options
  let qtyOpts = '';
  for (let q = 1; q <= 10; q++) {
    qtyOpts += `<option value="${q}" ${q === qtyNum ? 'selected' : ''}>${q}</option>`;
  }

  const itemHTML = `
  <div class="cart-item">
    <div>
      <img class="cart-item-img" src="${giftCardImg}" alt="Apple Gift Card"/>
    </div>
    <div class="cart-item-info">
      <h2>Apple Gift Card by Email</h2>
      <div class="gift-details">
        <div class="gift-details-header">
          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="4" width="18" height="14" rx="2" stroke="#1d1d1f" stroke-width="1.5"/>
            <path d="M1 8h18" stroke="#1d1d1f" stroke-width="1.5"/>
            <path d="M10 4V2" stroke="#1d1d1f" stroke-width="1.5"/>
          </svg>
          Your gift card details &nbsp;<span style="color:#0071e3;cursor:pointer;">| Edit ⊕</span>
        </div>
        ${toName || toEmail ? `<div class="gift-row"><strong>To:</strong><span>${toName}${toEmail ? ' (' + toEmail + ')' : ''}</span></div>` : ''}
        ${fromName || fromEmail ? `<div class="gift-row"><strong>From:</strong><span>${fromName}${fromEmail ? ' (' + fromEmail + ')' : ''}</span></div>` : ''}
        ${msg ? `<div class="gift-row"><strong>Message:</strong><span>${msg}</span></div>` : ''}
      </div>
      <div class="arrives">Usually arrives within 1 hour</div>
    </div>
    <div class="qty-select-wrap" style="padding-top:4px;">
      <select class="qty-select" onchange="updateQty(this, ${i})">
        ${qtyOpts}
      </select>
      <span style="font-size:13px;color:#1d1d1f;">&#8964;</span>
    </div>
    <div>
      <div class="cart-item-price" id="item-price-${i}">${formatPrice(itemTotal)}</div>
      <div class="cart-item-actions">
        <a href="#">Remove</a>
        <a href="#">Save for later</a>
      </div>
    </div>
  </div>`;
  container.insertAdjacentHTML('beforeend', itemHTML);
}

// Default demo items if no URL params
if (!hasItems) {
  const defaults = [
    { toName:'hamad', toEmail:'hamad12@hotmail.com', fromName:'hamada', fromEmail:'hamad12@hotmail.com', msg:'best gift vocher', qty:1, price:50 },
    { toName:'hamad', toEmail:'hamads@hotmail.com',  fromName:'hadamd', fromEmail:'haamad@hotmail.com',  msg:'best gift hamada', qty:1, price:50 },
  ];
  defaults.forEach((d, idx) => {
    const i = idx + 1;
    grandTotal += d.price * d.qty;
    let qtyOpts = '';
    for (let q = 1; q <= 10; q++) qtyOpts += `<option ${q===d.qty?'selected':''}>${q}</option>`;
    container.insertAdjacentHTML('beforeend', `
    <div class="cart-item">
      <div><img class="cart-item-img" src="${giftCardImg}" alt="Apple Gift Card"/></div>
      <div class="cart-item-info">
        <h2>Apple Gift Card by Email</h2>
        <div class="gift-details">
          <div class="gift-details-header">
            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="1" y="4" width="18" height="14" rx="2" stroke="#1d1d1f" stroke-width="1.5"/>
              <path d="M1 8h18" stroke="#1d1d1f" stroke-width="1.5"/>
            </svg>
            Your gift card details &nbsp;<span style="color:#0071e3;cursor:pointer;">| Edit ⊕</span>
          </div>
          <div class="gift-row"><strong>To:</strong><span>${d.toName} (${d.toEmail})</span></div>
          <div class="gift-row"><strong>From:</strong><span>${d.fromName} (${d.fromEmail})</span></div>
          <div class="gift-row"><strong>Message:</strong><span>${d.msg}</span></div>
        </div>
        <div class="arrives">Usually arrives within 1 hour</div>
      </div>
      <div class="qty-select-wrap" style="padding-top:4px;">
        <select class="qty-select" onchange="updateQty(this, ${i})">
          ${qtyOpts}
        </select>
        <span style="font-size:13px;color:#1d1d1f;">&#8964;</span>
      </div>
      <div>
        <div class="cart-item-price" id="item-price-${i}">$${(d.price*d.qty).toFixed(2)}</div>
        <div class="cart-item-actions"><a href="#">Remove</a><a href="#">Save for later</a></div>
      </div>
    </div>`);
  });
}

// Update totals
function updateTotals() {
  document.getElementById('subtotal').textContent = formatPrice(grandTotal);
  document.getElementById('total').textContent = formatPrice(grandTotal);
  document.getElementById('bag-total-heading').textContent = `Your bag total is ${formatPrice(grandTotal)}.`;
}
updateTotals();

// Handle quantity change
const itemPrices = {};
// Store base unit prices per item
for (let i = 1; i <= 5; i++) {
  const price = parseFloat(p(`price${i}`, '0')) || 0;
  itemPrices[i] = price;
}
// For defaults
if (!hasItems) { itemPrices[1] = 50; itemPrices[2] = 50; }

function updateQty(sel, idx) {
  const qty = parseInt(sel.value);
  const basePrice = itemPrices[idx] || 0;
  const newTotal = basePrice * qty;
  const el = document.getElementById(`item-price-${idx}`);
  if (el) el.textContent = formatPrice(newTotal);
  // Recalculate grand total
  let newGrand = 0;
  document.querySelectorAll('.cart-item-price').forEach(el => {
    newGrand += parseFloat(el.textContent.replace('$','')) || 0;
  });
  grandTotal = newGrand;
  updateTotals();
}

// Questions toggle
function toggleQ() {
  const body = document.getElementById('qbody');
  const chev = document.getElementById('qchevron');
  body.classList.toggle('open');
  chev.classList.toggle('open');
}
</script>
